#!/bin/bash
# KEEL commit-msg hook
# Enforces commit message format: keel(NN): description
# Install: cp hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -n 1 "$COMMIT_MSG_FILE")

# Allow merge commits and initial commits
if [[ "$COMMIT_MSG" =~ ^Merge ]] || [[ "$COMMIT_MSG" =~ ^Initial ]]; then
  exit 0
fi

# Allow fixup and squash commits
if [[ "$COMMIT_MSG" =~ ^(fixup|squash)! ]]; then
  exit 0
fi

# Enforce KEEL format: keel(NN): description
# Accepts: keel(01): task 1 — description
# Accepts: keel(01): phase complete — description
# Accepts: keel: initial setup
if [[ ! "$COMMIT_MSG" =~ ^keel(\([0-9]{2}\))?:\ .+ ]]; then
  echo ""
  echo -e "${RED}[KEEL] Invalid commit message format.${NC}"
  echo ""
  echo "  Expected: keel(NN): description"
  echo ""
  echo "  Examples:"
  echo "    keel(01): task 1 — initialize project scaffolding"
  echo "    keel(01): phase complete — foundation with auth"
  echo "    keel: initial project setup"
  echo ""
  echo -e "${RED}  Bypass with: git commit --no-verify${NC}"
  exit 1
fi

exit 0
