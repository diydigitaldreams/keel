#!/bin/bash
# KEEL pre-commit hook
# Enforces LOG.md updates and secret detection.
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# ─── Colors ───
RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

# ─── 1. Commit message format ───
# Note: pre-commit doesn't have access to the commit message.
# This check runs in commit-msg hook instead. See hooks/commit-msg.

# ─── 2. Secret detection ───
# Scan staged files for common secret patterns

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -n "$STAGED_FILES" ]; then
  # Patterns that indicate secrets
  SECRET_PATTERNS=(
    # Private keys
    'PRIVATE KEY'
    'BEGIN RSA PRIVATE KEY'
    'BEGIN DSA PRIVATE KEY'
    'BEGIN EC PRIVATE KEY'
    'BEGIN OPENSSH PRIVATE KEY'
    'BEGIN PGP PRIVATE KEY'
    # OpenAI / generic sk- keys
    'sk-[a-zA-Z0-9]{20,}'
    # Anthropic
    'sk-ant-[a-zA-Z0-9]+'
    # GitHub tokens
    'ghp_[a-zA-Z0-9]{36}'
    'gho_[a-zA-Z0-9]{36}'
    'ghs_[a-zA-Z0-9]{36}'
    'ghu_[a-zA-Z0-9]{36}'
    'github_pat_[a-zA-Z0-9_]{22,}'
    # GitLab
    'glpat-[a-zA-Z0-9\-]{20}'
    # Slack
    'xox[bapors]-[a-zA-Z0-9\-]+'
    # AWS
    'AKIA[0-9A-Z]{16}'
    'ASIA[0-9A-Z]{16}'
    # Google
    'AIza[0-9A-Za-z\-_]{35}'
    # Stripe
    'sk_live_[0-9a-zA-Z]{24,}'
    'pk_live_[0-9a-zA-Z]{24,}'
    'rk_live_[0-9a-zA-Z]{24,}'
    # Twilio (anchored to word boundary to reduce false positives)
    '(^|[^a-zA-Z0-9])SK[0-9a-fA-F]{32}([^a-zA-Z0-9]|$)'
    '(^|[^a-zA-Z0-9])AC[0-9a-fA-F]{32}([^a-zA-Z0-9]|$)'
    # Azure
    'DefaultEndpointsProtocol=https'
    # SendGrid
    'SG\.[a-zA-Z0-9\-_]{22}\.[a-zA-Z0-9\-_]{43}'
    # Mailgun
    'key-[0-9a-zA-Z]{32}'
    # Generic password assignments
    'password\s*[:=]\s*["\x27][^"\x27]{8,}'
    # Generic secret/token assignments
    'secret\s*[:=]\s*["\x27][^"\x27]{8,}'
    'api_key\s*[:=]\s*["\x27][^"\x27]{8,}'
    'apikey\s*[:=]\s*["\x27][^"\x27]{8,}'
  )

  while IFS= read -r file; do
    [ -z "$file" ] && continue

    # Skip binary files, lock files, and the hook itself
    if [[ "$file" == *.lock ]] || [[ "$file" == *.png ]] || [[ "$file" == *.jpg ]] || \
       [[ "$file" == *.gif ]] || [[ "$file" == *.ico ]] || [[ "$file" == *.woff ]] || \
       [[ "$file" == *.woff2 ]] || [[ "$file" == *.ttf ]] || [[ "$file" == *.eot ]] || \
       [[ "$file" == *.pdf ]] || [[ "$file" == *.zip ]] || [[ "$file" == *.tar.gz ]] || \
       [[ "$file" == hooks/* ]]; then
      continue
    fi

    # Skip if file doesn't exist (deleted)
    [ -f "$file" ] || continue

    for pattern in "${SECRET_PATTERNS[@]}"; do
      if grep -qE "$pattern" "$file" 2>/dev/null; then
        echo -e "${RED}[KEEL] Possible secret detected in ${file}${NC}"
        echo -e "${RED}       Pattern: ${pattern}${NC}"
        ERRORS=$((ERRORS + 1))
      fi
    done
  done <<< "$STAGED_FILES"

  # Check for .env files being committed (should be in .gitignore)
  while IFS= read -r file; do
    [ -z "$file" ] && continue

    # Match .env and any .env.* variant
    if [[ "$file" == .env ]] || [[ "$file" == .env.* ]] || \
       [[ "$file" == */.env ]] || [[ "$file" == */.env.* ]]; then
      echo -e "${RED}[KEEL] Environment file staged for commit: ${file}${NC}"
      echo -e "${RED}       Add it to .gitignore instead.${NC}"
      ERRORS=$((ERRORS + 1))
    fi
  done <<< "$STAGED_FILES"

  # ─── 3. LOG.md check ───
  # If committing phase work, LOG.md should be updated too

  while IFS= read -r file; do
    [ -z "$file" ] && continue

    # Detect if we're committing code inside a phase directory
    if [[ "$file" =~ ^docs/phases/[0-9]{2}- ]] && [[ "$file" != *LOG.md ]] && [[ "$file" != *PLAN.md ]]; then
      PHASE_DIR=$(echo "$file" | grep -oE 'docs/phases/[0-9]{2}-[^/]+')
      if [ -n "$PHASE_DIR" ]; then
        # Check if LOG.md is also being updated in this commit
        if ! echo "$STAGED_FILES" | grep -q "${PHASE_DIR}/LOG.md"; then
          echo -e "${YELLOW}[KEEL] Warning: Committing phase files without updating ${PHASE_DIR}/LOG.md${NC}"
          # Warning only, not a block
        fi
      fi
    fi
  done <<< "$STAGED_FILES"
fi

# ─── Result ───
if [ $ERRORS -gt 0 ]; then
  echo ""
  echo -e "${RED}[KEEL] Commit blocked: ${ERRORS} issue(s) found.${NC}"
  echo -e "${RED}       Fix the issues above, or bypass with: git commit --no-verify${NC}"
  exit 1
fi

exit 0
